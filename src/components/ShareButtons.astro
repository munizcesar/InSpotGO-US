---
const { title, url } = Astro.props;
const encodedUrl   = encodeURIComponent(url);
const encodedTitle = encodeURIComponent(title);
---

<div class="share-bar">
  <span class="share-label">Share:</span>

  <div class="share-icons">
    <a href={`https://x.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}&via=InSpotGO`}
      target="_blank" rel="noopener noreferrer"
      class="share-btn" data-color="#000" aria-label="X" title="X">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
    </a>
    <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`}
      target="_blank" rel="noopener noreferrer"
      class="share-btn" data-color="#0A66C2" aria-label="LinkedIn" title="LinkedIn">
      <svg viewBox="0 0 24 24" width="19" height="19" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
    </a>
    <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`}
      target="_blank" rel="noopener noreferrer"
      class="share-btn" data-color="#1877F2" aria-label="Facebook" title="Facebook">
      <svg viewBox="0 0 24 24" width="19" height="19" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
    </a>
    <a href={`https://t.me/share/url?url=${encodedUrl}&text=${encodedTitle}`}
      target="_blank" rel="noopener noreferrer"
      class="share-btn" data-color="#229ED9" aria-label="Telegram" title="Telegram">
      <svg viewBox="0 0 24 24" width="19" height="19" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
    </a>
    <a href={`mailto:?subject=${encodedTitle}&body=Check%20this%20out%3A%20${encodedUrl}`}
      class="share-btn" data-color="#6b7280" aria-label="Email" title="Email">
      <svg viewBox="0 0 24 24" width="19" height="19" fill="currentColor"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
    </a>
    <button class="share-btn" data-color="#374151" id="share-copy-us" aria-label="Copy link" title="Copy link">
      <svg id="icon-copy-us" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
      <svg id="icon-check-us" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.5" style="display:none"><polyline points="20 6 9 17 4 12"/></svg>
    </button>
    <button class="share-btn" data-color="#374151" id="share-native-us" style="display:none" aria-label="Share">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z"/></svg>
    </button>
  </div>
</div>

<script>
(function(){
  document.querySelectorAll('.share-btn[data-color]').forEach(function(btn) {
    var color = btn.getAttribute('data-color');
    btn.addEventListener('mouseenter', function() {
      btn.style.background = color;
      btn.style.color = '#fff';
    });
    btn.addEventListener('mouseleave', function() {
      btn.style.background = '';
      btn.style.color = '';
    });
  });

  var copyBtn   = document.getElementById('share-copy-us');
  var iconCopy  = document.getElementById('icon-copy-us');
  var iconCheck = document.getElementById('icon-check-us');
  if (copyBtn) {
    copyBtn.addEventListener('click', function(){
      navigator.clipboard.writeText(window.location.href).then(function(){
        if (iconCopy)  iconCopy.style.display  = 'none';
        if (iconCheck) iconCheck.style.display = 'inline';
        copyBtn.style.background = '#22c55e';
        copyBtn.style.color = '#fff';
        setTimeout(function(){
          if (iconCopy)  iconCopy.style.display  = 'inline';
          if (iconCheck) iconCheck.style.display = 'none';
          copyBtn.style.background = '';
          copyBtn.style.color = '';
        }, 1800);
      }).catch(function(){});
    });
  }

  var nativeBtn = document.getElementById('share-native-us');
  if (nativeBtn && navigator.share) {
    nativeBtn.style.display = 'flex';
    nativeBtn.addEventListener('click', function(){
      navigator.share({ title: document.title, url: window.location.href }).catch(function(){});
    });
  }
})();
</script>

<style>
  .share-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin: 1.75rem 0;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .share-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--color-text-muted, #6b7280);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    white-space: nowrap;
  }

  .share-icons {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-surface-offset, #e5e7eb);
    color: var(--color-text, #374151);
    text-decoration: none !important;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.18s ease, transform 0.15s ease, color 0.18s ease;
  }
  .share-btn:hover  { transform: translateY(-2px); }
  .share-btn:active { transform: scale(0.94); }

  @media (max-width: 480px) {
    .share-label { display: none; }
    .share-bar   { gap: 0; }
    .share-icons { gap: 0.4rem; }
    .share-btn   { width: 38px; height: 38px; }
  }
</style>
