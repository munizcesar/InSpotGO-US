---
import "../styles/global.css";
---
<header class="header" role="banner">
  <div class="container container-flex">
    <a href="/" class="logo-link" aria-label="InSpotGO home">
      <!-- Unified logo (desktop + mobile): Icon + Text -->
      <span class="logo-wrap">
        <img src="/logo-icon.svg" alt="" class="logo-icon" height="40" width="40" />
        <span class="logo-text" aria-hidden="true">
          <span class="logo-spot">InSpot</span><span class="logo-go">GO</span>
        </span>
      </span>
    </a>

    <!-- Mobile Menu Toggle Button -->
    <button
      class="mobile-menu-toggle"
      aria-label="Toggle navigation menu"
      aria-expanded="false"
      id="mobile-menu-toggle"
    >
      <span class="hamburger"></span>
      <span class="hamburger"></span>
      <span class="hamburger"></span>
    </button>

    <!-- Mobile Drawer Backdrop (Overlay) -->
    <div class="drawer-backdrop" id="drawer-backdrop" aria-hidden="true"></div>

    <!-- Navigation -->
    <nav aria-label="Main navigation" class="nav" id="main-nav">
      <a href="/tech" class="nav-link">Tech</a>
      <a href="/saas" class="nav-link">SaaS</a>
      <a href="/software" class="nav-link">Software</a>
      <a href="/guides" class="nav-link">Guides</a>
      <a href="/about" class="nav-link">About</a>
      <a href="/contact" class="nav-link">Contact</a>
    </nav>
  </div>
</header>

<style>
  .header {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 1000;
    backdrop-filter: blur(8px);
    background: rgba(255, 255, 255, 0.95);
  }

  .container-flex {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  /* Logo Styles */
  .logo-link {
    text-decoration: none;
    display: flex;
    align-items: center;
    transition: transform 0.3s ease;
    z-index: 1001;
  }

  .logo-link:hover {
    transform: scale(1.05);
  }

  .logo-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
  }

  .logo-icon {
    display: block;
    height: 40px;
    width: 40px;
  }

  .logo-text {
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
    line-height: 1;
    user-select: none;
    white-space: nowrap;
  }

  /* Logo uses global.css classes:
     .logo-spot { color: #2E1155 }
     .logo-go { gradient orange-to-pink } */

  /* Mobile Menu Toggle Button */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-around;
    width: 2rem;
    height: 2rem;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
    position: relative;
  }

  .mobile-menu-toggle:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
  }

  .hamburger {
    width: 2rem;
    height: 0.2rem;
    background: var(--color-text);
    border-radius: 10px;
    transition: all 0.3s ease;
    transform-origin: center;
  }

  /* Hamburger Animation */
  .mobile-menu-toggle.active .hamburger:nth-child(1) {
    transform: translateY(0.6rem) rotate(45deg);
  }

  .mobile-menu-toggle.active .hamburger:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.active .hamburger:nth-child(3) {
    transform: translateY(-0.6rem) rotate(-45deg);
  }

  /* Navigation */
  .nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-link {
    color: var(--color-text);
    text-decoration: none;
    font-weight: 500;
    font-size: 1rem;
    transition: color 0.3s ease;
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-primary);
    transition: width 0.3s ease;
  }

  .nav-link:hover {
    color: var(--color-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* Mobile Drawer Backdrop (Overlay) */
  .drawer-backdrop {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh; /* Dynamic Viewport Height for mobile browsers */
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
    opacity: 0;
    transition: opacity 0.3s ease;
    will-change: opacity;
  }

  .drawer-backdrop.active {
    display: block;
    opacity: 1;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .container-flex {
      padding: 0.875rem 1rem;
    }

    /* Show hamburger button */
    .mobile-menu-toggle {
      display: flex;
    }

    /* Backdrop should still be hidden by default; .active class toggles visibility */
    /* (previous rule unconditionally showed it on small screens, blocking all taps) */
    .drawer-backdrop {
      display: none;
    }

    /* Mobile Navigation Drawer */
    .nav {
      position: fixed;
      top: 0;
      right: 0;
      height: 100dvh; /* Dynamic Viewport Height - accounts for mobile browser toolbars */
      width: 70%;
      max-width: 300px;
      background: var(--color-bg);
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
      padding: 5rem 2rem 2rem;
      /* Hardware acceleration: translate3d for 60fps smooth animation */
      transform: translate3d(100%, 0, 0);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: -2px 0 10px rgba(0, 0, 0, 0.1);
      /* drawer must float above header/logo */
      z-index: 1002;
      will-change: transform;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch; /* Smooth scrolling on iOS */
    }

    .nav.active {
      transform: translate3d(0, 0, 0); /* Hardware accelerated slide-in */
    }

    .nav-link {
      width: 100%;
      padding: 1rem 0;
      font-size: 1.1rem;
      border-bottom: 1px solid var(--color-border);
    }

    .nav-link:last-child {
      border-bottom: none;
    }

    .nav-link::after {
      display: none;
    }
  }

  @media (max-width: 360px) {
    .logo-icon {
      height: 36px;
      width: 36px;
    }

    .logo-text {
      font-size: 1.125rem;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function() {
    const menuToggle = document.getElementById('mobile-menu-toggle');
    const nav = document.getElementById('main-nav');
    const backdrop = document.getElementById('drawer-backdrop');

    function openDrawer() {
      menuToggle?.classList.add('active');
      nav?.classList.add('active');
      backdrop?.classList.add('active');
      menuToggle?.setAttribute('aria-expanded', 'true');
      backdrop?.setAttribute('aria-hidden', 'false');
      // Prevent scroll-chaining: lock body scroll when drawer is open
      document.body.style.overflow = 'hidden';
      // Prevent iOS bounce scroll
      document.body.style.position = 'fixed';
      document.body.style.width = '100%';
    }

    function closeDrawer() {
      menuToggle?.classList.remove('active');
      nav?.classList.remove('active');
      backdrop?.classList.remove('active');
      menuToggle?.setAttribute('aria-expanded', 'false');
      backdrop?.setAttribute('aria-hidden', 'true');
      // Restore body scroll
      document.body.style.overflow = '';
      document.body.style.position = '';
      document.body.style.width = '';
    }

    if (menuToggle && nav && backdrop) {
      // Toggle drawer on hamburger click
      menuToggle.addEventListener('click', function(e) {
        e.stopPropagation();
        if (nav.classList.contains('active')) {
          closeDrawer();
        } else {
          openDrawer();
        }
      });

      // Close drawer when clicking backdrop
      backdrop.addEventListener('click', function() {
        closeDrawer();
      });

      // Close drawer when clicking nav links
      const navLinks = nav.querySelectorAll('.nav-link');
      navLinks.forEach(function(link) {
        link.addEventListener('click', function() {
          closeDrawer();
        });
      });

      // Close drawer on outside click (desktop behavior)
      document.addEventListener('click', function(e) {
        if (
          nav.classList.contains('active') &&
          !nav.contains(e.target) &&
          !menuToggle.contains(e.target) &&
          !backdrop.contains(e.target)
        ) {
          closeDrawer();
        }
      });

      // Close drawer on Escape key (accessibility)
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && nav.classList.contains('active')) {
          closeDrawer();
          menuToggle?.focus(); // Return focus to toggle button
        }
      });

      // Close drawer on window resize (if resizing to desktop)
      window.addEventListener('resize', function() {
        if (window.innerWidth > 768 && nav.classList.contains('active')) {
          closeDrawer();
        }
      });
    }
  });
</script>
