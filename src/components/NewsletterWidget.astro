---
// NewsletterWidget — InSpotGO US
---

<div class="newsletter-widget" id="nl-widget-us">
  <div class="newsletter-icon">✉️</div>
  <h4>Stay in the Loop</h4>
  <p>Get the best reviews delivered straight to your inbox</p>

  <form class="newsletter-form" id="nl-form-us">
    <input
      type="email"
      name="email"
      placeholder="Your email"
      class="newsletter-input"
      required
      autocomplete="email"
    />
    <button type="submit" class="newsletter-button">
      <span class="btn-text">Subscribe</span>
      <span class="btn-loading" style="display:none">Sending…</span>
    </button>
  </form>

  <div class="newsletter-success" id="nl-success-us" style="display:none">
    <span class="success-icon">✅</span>
    <p>You're subscribed! Thank you.</p>
  </div>

  <div class="newsletter-error" id="nl-error-us" style="display:none">
    <p id="nl-error-msg-us">⚠️ Something went wrong. Please try again.</p>
  </div>
</div>

<script>
(function() {
  var form = document.getElementById('nl-form-us');
  if (!form) return;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var input = form.querySelector('input[type="email"]');
    var btn = form.querySelector('button');
    var btnText = btn ? btn.querySelector('.btn-text') : null;
    var btnLoading = btn ? btn.querySelector('.btn-loading') : null;
    var successEl = document.getElementById('nl-success-us');
    var errorEl = document.getElementById('nl-error-us');
    var errorMsg = document.getElementById('nl-error-msg-us');

    var email = input ? input.value.trim() : '';
    if (!email) return;

    if (btn) btn.disabled = true;
    if (btnText) btnText.style.display = 'none';
    if (btnLoading) btnLoading.style.display = 'inline';
    if (errorEl) errorEl.style.display = 'none';

    fetch('/api/newsletter', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email: email }),
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.success) {
        if (form) form.style.display = 'none';
        if (successEl) successEl.style.display = 'flex';
      } else {
        if (errorMsg) errorMsg.textContent = '\u26a0\ufe0f ' + (data.error || 'Something went wrong. Please try again.');
        if (errorEl) errorEl.style.display = 'block';
        if (btn) btn.disabled = false;
        if (btnText) btnText.style.display = 'inline';
        if (btnLoading) btnLoading.style.display = 'none';
      }
    })
    .catch(function() {
      if (errorMsg) errorMsg.textContent = '\u26a0\ufe0f Connection error. Please try again.';
      if (errorEl) errorEl.style.display = 'block';
      if (btn) btn.disabled = false;
      if (btnText) btnText.style.display = 'inline';
      if (btnLoading) btnLoading.style.display = 'none';
    });
  });
})();
</script>

<style>
  .newsletter-widget {
    background: linear-gradient(135deg, #5b21b6, #7c3aed);
    border-radius: var(--radius-lg, 12px);
    padding: 1.5rem;
    color: white;
    margin-top: 2rem;
    text-align: center;
  }
  .newsletter-icon { font-size: 1.75rem; margin-bottom: 0.5rem; }
  .newsletter-widget h4 { font-size: 1.2rem; font-weight: 700; margin: 0 0 0.4rem 0; }
  .newsletter-widget p { font-size: 0.875rem; margin: 0 0 1.25rem 0; opacity: 0.92; }
  .newsletter-form { display: flex; flex-direction: column; gap: 0.625rem; }
  .newsletter-input {
    padding: 0.75rem 1rem;
    border: 2px solid rgba(255,255,255,0.35);
    border-radius: var(--radius-md, 8px);
    background: rgba(255,255,255,0.15);
    color: white;
    font-size: 0.9rem;
    width: 100%;
    box-sizing: border-box;
  }
  .newsletter-input::placeholder { color: rgba(255,255,255,0.65); }
  .newsletter-input:focus { outline: none; border-color: white; background: rgba(255,255,255,0.22); }
  .newsletter-button {
    padding: 0.75rem;
    background: white;
    color: #5b21b6;
    border: none;
    border-radius: var(--radius-md, 8px);
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    width: 100%;
  }
  .newsletter-button:hover:not(:disabled) { opacity: 0.9; }
  .newsletter-button:disabled { opacity: 0.7; cursor: not-allowed; }
  .newsletter-success {
    display: none;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 0;
  }
  .success-icon { font-size: 2rem; }
  .newsletter-success p { font-size: 1rem; font-weight: 600; margin: 0; opacity: 1; }
  .newsletter-error {
    background: rgba(255,255,255,0.15);
    border-radius: 6px;
    padding: 0.5rem 0.75rem;
    margin-top: 0.5rem;
    display: none;
  }
  .newsletter-error p { font-size: 0.82rem; margin: 0; color: #ffe4e4; }
</style>
