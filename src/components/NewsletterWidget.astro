---
// NewsletterWidget — newsletter widget with Resend
// Used in LatestNewsSection sidebar
---

<div class="newsletter-widget">
  <h4>Fique por Dentro</h4>
  <p>Receba os melhores reviews direto no seu e-mail</p>

  <form class="newsletter-form" id="newsletter-form-us">
    <input
      type="email"
      placeholder="Seu e-mail"
      class="newsletter-input"
      id="newsletter-email-us"
      required
      autocomplete="email"
    />
    <button type="submit" class="newsletter-button" id="newsletter-btn-us">
      <span class="btn-text">Assinar</span>
      <span class="btn-loading" hidden>Enviando...</span>
    </button>
  </form>

  <div class="newsletter-success" id="newsletter-success-us" hidden>
    <span class="success-icon">✅</span>
    <p>Assinatura realizada com sucesso!</p>
  </div>

  <div class="newsletter-error" id="newsletter-error-us" hidden>
    <span class="error-icon">⚠️</span>
    <p id="newsletter-error-msg-us">Algo deu errado. Tente novamente.</p>
  </div>
</div>

<script>
  const form = document.getElementById('newsletter-form-us') as HTMLFormElement | null;
  const btn = document.getElementById('newsletter-btn-us') as HTMLButtonElement | null;
  const btnText = btn?.querySelector('.btn-text') as HTMLElement | null;
  const btnLoading = btn?.querySelector('.btn-loading') as HTMLElement | null;
  const successEl = document.getElementById('newsletter-success-us') as HTMLElement | null;
  const errorEl = document.getElementById('newsletter-error-us') as HTMLElement | null;
  const errorMsg = document.getElementById('newsletter-error-msg-us') as HTMLElement | null;
  const emailInput = document.getElementById('newsletter-email-us') as HTMLInputElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput?.value.trim();
    if (!email) return;

    if (btn) btn.disabled = true;
    if (btnText) btnText.hidden = true;
    if (btnLoading) btnLoading.hidden = false;
    if (errorEl) errorEl.hidden = true;

    try {
      const res = await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();

      if (res.ok && data.success) {
        if (form) form.hidden = true;
        if (successEl) successEl.hidden = false;
      } else {
        if (errorMsg) errorMsg.textContent = data.error || 'Algo deu errado. Tente novamente.';
        if (errorEl) errorEl.hidden = false;
        if (btn) btn.disabled = false;
        if (btnText) btnText.hidden = false;
        if (btnLoading) btnLoading.hidden = true;
      }
    } catch {
      if (errorMsg) errorMsg.textContent = 'Erro de conexao. Tente novamente.';
      if (errorEl) errorEl.hidden = false;
      if (btn) btn.disabled = false;
      if (btnText) btnText.hidden = false;
      if (btnLoading) btnLoading.hidden = true;
    }
  });
</script>

<style>
  .newsletter-widget {
    background: linear-gradient(135deg, #3b1f8a 0%, #4a23a3 100%);
    border-radius: 14px;
    padding: 1.5rem;
    color: white;
    margin-top: 2rem;
    box-shadow: 0 14px 36px rgba(46, 17, 85, 0.25);
  }

  .newsletter-widget h4 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 0.65rem 0;
  }

  .newsletter-widget p {
    font-size: 1rem;
    margin: 0 0 1.2rem 0;
    opacity: 0.95;
    max-width: 100%;
  }

  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .newsletter-input {
    padding: 0.78rem 0.95rem;
    border: none;
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.9);
    color: #1f2937;
    font-size: 1rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .newsletter-input::placeholder { color: #6b7280; }

  .newsletter-input:focus {
    outline: none;
    background: white;
    box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.4);
  }

  .newsletter-button {
    padding: 0.78rem;
    background: white;
    color: #2f1b7a;
    border: none;
    border-radius: 9px;
    font-weight: 700;
    font-size: 1.05rem;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
  }

  .newsletter-button:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(255, 255, 255, 0.32);
  }

  .newsletter-button:disabled { opacity: 0.7; cursor: not-allowed; }

  .newsletter-success {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 0;
  }

  .success-icon { font-size: 2rem; }

  .newsletter-success p {
    font-size: 0.95rem;
    font-weight: 600;
    margin: 0;
    opacity: 1;
  }

  .newsletter-error {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(255,255,255,0.16);
    border-radius: 8px;
    padding: 0.5rem 0.75rem;
    margin-top: 0.5rem;
  }

  .newsletter-error p {
    font-size: 0.82rem;
    margin: 0;
    opacity: 1;
    color: #ffe4e4;
    text-align: left;
    max-width: 100%;
  }

  @media (max-width: 768px) {
    .newsletter-widget {
      padding: 1.25rem;
    }

    .newsletter-widget h4 {
      font-size: 1.7rem;
    }

    .newsletter-widget p {
      font-size: 0.95rem;
    }
  }
</style>
