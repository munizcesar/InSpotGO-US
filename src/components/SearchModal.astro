---
// SearchModal — client-side search using /search-index.json
---

<!-- Search trigger button (injected into header via slot or standalone) -->
<button class="search-trigger" id="search-trigger" aria-label="Search" title="Search (Ctrl+K)">
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="20" height="20">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
</button>

<!-- Modal overlay -->
<div class="search-overlay" id="search-overlay" role="dialog" aria-modal="true" aria-label="Search" hidden>
  <div class="search-modal">
    <div class="search-header">
      <div class="search-input-wrap">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          type="search"
          id="search-input"
          class="search-input"
          placeholder="Search reviews, products, guides..."
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="search-esc-hint">ESC</kbd>
      </div>
      <button class="search-close" id="search-close" aria-label="Close search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="search-body" id="search-body">
      <div class="search-empty" id="search-empty">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="40" height="40" style="color:#d1d5db;margin-bottom:0.75rem">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <p>Type to search across all reviews &amp; guides</p>
        <span>Tip: press <kbd>Ctrl+K</kbd> to open search anytime</span>
      </div>
      <ul class="search-results" id="search-results" role="listbox" hidden></ul>
      <div class="search-no-results" id="search-no-results" hidden>
        <p>No results for "<span id="search-query-display"></span>"</p>
        <span>Try different keywords</span>
      </div>
    </div>

    <div class="search-footer">
      <span><kbd>&uarr;</kbd><kbd>&darr;</kbd> navigate</span>
      <span><kbd>Enter</kbd> open</span>
      <span><kbd>ESC</kbd> close</span>
    </div>
  </div>
</div>

<style>
  /* Trigger button */
  .search-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px; height: 38px;
    background: transparent;
    border: 1.5px solid var(--color-border, #e5e7eb);
    border-radius: 8px;
    color: var(--color-text-light, #6b7280);
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .search-trigger:hover {
    border-color: var(--color-primary, #f97316);
    color: var(--color-primary, #f97316);
    background: rgba(249,115,22,0.05);
  }
  .search-trigger:focus { outline: 2px solid var(--color-primary); outline-offset: 2px; }

  /* Overlay */
  .search-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    z-index: 9999;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 5vh 1rem 1rem;
    animation: overlayIn 0.15s ease;
  }
  .search-overlay[hidden] { display: none; }
  @keyframes overlayIn { from { opacity: 0; } to { opacity: 1; } }

  /* Modal */
  .search-modal {
    background: #fff;
    border-radius: 16px;
    box-shadow: 0 24px 64px rgba(0,0,0,0.22);
    width: 100%; max-width: 620px;
    overflow: hidden;
    animation: modalIn 0.18s cubic-bezier(0.4,0,0.2,1);
  }
  @keyframes modalIn { from { opacity: 0; transform: translateY(-12px) scale(0.98); } to { opacity: 1; transform: none; } }

  /* Header */
  .search-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1rem;
    border-bottom: 1px solid #f3f4f6;
  }
  .search-input-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.625rem;
    background: #f9fafb;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    padding: 0.5rem 0.75rem;
    transition: border-color 0.2s;
  }
  .search-input-wrap:focus-within { border-color: var(--color-primary, #f97316); background: #fff; }
  .search-icon { color: #9ca3af; flex-shrink: 0; }
  .search-input {
    flex: 1; border: none; background: transparent;
    font-size: 1rem; color: #111827;
    outline: none;
    min-width: 0;
  }
  .search-input::placeholder { color: #9ca3af; }
  .search-esc-hint {
    font-size: 0.7rem; color: #9ca3af;
    background: #f3f4f6; border: 1px solid #e5e7eb;
    border-radius: 4px; padding: 0.1rem 0.35rem;
    flex-shrink: 0;
  }
  .search-close {
    display: flex; align-items: center; justify-content: center;
    width: 34px; height: 34px;
    background: #f3f4f6; border: none;
    border-radius: 8px; color: #6b7280;
    cursor: pointer; flex-shrink: 0;
    transition: background 0.15s, color 0.15s;
  }
  .search-close:hover { background: #fee2e2; color: #ef4444; }

  /* Body */
  .search-body { max-height: 420px; overflow-y: auto; }
  .search-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 2.5rem 1rem; color: #9ca3af; text-align: center;
  }
  .search-empty p { font-size: 0.95rem; margin: 0 0 0.4rem; color: #6b7280; }
  .search-empty span { font-size: 0.8rem; }
  .search-empty kbd, .search-footer kbd {
    font-size: 0.7rem; background: #f3f4f6;
    border: 1px solid #e5e7eb; border-radius: 4px;
    padding: 0.1rem 0.35rem; font-family: inherit;
  }

  /* Results */
  .search-results { list-style: none; margin: 0; padding: 0.5rem 0; }
  .search-result-item {
    display: flex; align-items: center; gap: 0.875rem;
    padding: 0.75rem 1rem;
    cursor: pointer;
    transition: background 0.1s;
    text-decoration: none;
    color: inherit;
    border-radius: 0;
  }
  .search-result-item:hover,
  .search-result-item.focused { background: #f9fafb; }
  .search-result-thumb {
    width: 52px; height: 40px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    background: #f3f4f6;
  }
  .search-result-thumb-placeholder {
    width: 52px; height: 40px;
    border-radius: 6px;
    background: linear-gradient(135deg, #f97316, #ec4899);
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    color: white; font-size: 0.65rem; font-weight: 700;
  }
  .search-result-body { flex: 1; min-width: 0; }
  .search-result-title {
    font-size: 0.9rem; font-weight: 600;
    color: #111827; line-height: 1.3;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    margin-bottom: 0.2rem;
  }
  .search-result-title mark { background: rgba(249,115,22,0.18); color: #c2410c; border-radius: 2px; padding: 0 1px; }
  .search-result-meta {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.72rem; color: #9ca3af;
  }
  .search-result-category {
    background: #f3f4f6; color: #6b7280;
    border-radius: 4px; padding: 0.1rem 0.4rem;
    font-weight: 500; text-transform: uppercase; font-size: 0.65rem; letter-spacing: 0.04em;
  }
  .search-result-arrow { color: #d1d5db; flex-shrink: 0; }

  .search-no-results {
    padding: 2rem 1rem; text-align: center; color: #9ca3af;
  }
  .search-no-results p { font-size: 0.95rem; color: #6b7280; margin-bottom: 0.25rem; }
  .search-no-results span { font-size: 0.8rem; }

  /* Footer */
  .search-footer {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.625rem 1rem;
    border-top: 1px solid #f3f4f6;
    font-size: 0.72rem; color: #9ca3af;
  }
  .search-footer span { display: flex; align-items: center; gap: 0.25rem; }

  @media (max-width: 480px) {
    .search-overlay { padding: 0; align-items: flex-end; }
    .search-modal { border-radius: 20px 20px 0 0; max-width: 100%; }
    .search-esc-hint { display: none; }
    .search-footer { display: none; }
  }
</style>

<script is:inline>
  (function() {
    let searchIndex = null;
    let currentFocus = -1;

    const trigger = document.getElementById('search-trigger');
    const overlay = document.getElementById('search-overlay');
    const input = document.getElementById('search-input');
    const closeBtn = document.getElementById('search-close');
    const resultsList = document.getElementById('search-results');
    const emptyState = document.getElementById('search-empty');
    const noResults = document.getElementById('search-no-results');
    const queryDisplay = document.getElementById('search-query-display');

    async function loadIndex() {
      if (searchIndex) return;
      try {
        const res = await fetch('/search-index.json');
        searchIndex = await res.json();
      } catch(e) { searchIndex = []; }
    }

    function openSearch() {
      overlay.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => input.focus(), 50);
      loadIndex();
    }
    function closeSearch() {
      overlay.setAttribute('hidden', '');
      document.body.style.overflow = '';
      input.value = '';
      showEmpty();
      currentFocus = -1;
    }
    function showEmpty() {
      emptyState.style.display = 'flex';
      resultsList.hidden = true;
      noResults.hidden = true;
      resultsList.innerHTML = '';
    }

    function highlight(text, query) {
      if (!query) return text;
      const escaped = query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      return text.replace(new RegExp('(' + escaped + ')', 'gi'), '<mark>$1</mark>');
    }

    function search(query) {
      if (!query.trim()) { showEmpty(); return; }
      const q = query.toLowerCase().trim();
      const results = (searchIndex || []).filter(item => {
        return (
          item.title.toLowerCase().includes(q) ||
          item.description.toLowerCase().includes(q) ||
          item.category.toLowerCase().includes(q) ||
          (item.tags || []).some(t => t.toLowerCase().includes(q))
        );
      }).slice(0, 12);

      emptyState.style.display = 'none';
      currentFocus = -1;

      if (results.length === 0) {
        resultsList.hidden = true;
        resultsList.innerHTML = '';
        noResults.hidden = false;
        if (queryDisplay) queryDisplay.textContent = query;
        return;
      }
      noResults.hidden = true;
      resultsList.hidden = false;
      resultsList.innerHTML = results.map((item, i) => {
        const thumb = item.image
          ? `<img class="search-result-thumb" src="${item.image}" alt="" loading="lazy" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'">
             <div class="search-result-thumb-placeholder" style="display:none">${item.category.slice(0,3).toUpperCase()}</div>`
          : `<div class="search-result-thumb-placeholder">${item.category.slice(0,3).toUpperCase()}</div>`;
        return `
          <li role="option">
            <a class="search-result-item" href="/posts/${item.slug}" data-index="${i}">
              ${thumb}
              <div class="search-result-body">
                <div class="search-result-title">${highlight(item.title, query)}</div>
                <div class="search-result-meta">
                  <span class="search-result-category">${item.category}</span>
                  <span>${item.date}</span>
                  <span>${item.readTime}</span>
                </div>
              </div>
              <svg class="search-result-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14"><polyline points="9 18 15 12 9 6"/></svg>
            </a>
          </li>`;
      }).join('');
    }

    function moveFocus(dir) {
      const items = resultsList.querySelectorAll('.search-result-item');
      if (!items.length) return;
      items.forEach(el => el.classList.remove('focused'));
      currentFocus = (currentFocus + dir + items.length) % items.length;
      items[currentFocus]?.classList.add('focused');
      items[currentFocus]?.scrollIntoView({ block: 'nearest' });
    }

    // Events
    trigger?.addEventListener('click', openSearch);
    closeBtn?.addEventListener('click', closeSearch);
    overlay?.addEventListener('click', function(e) { if (e.target === overlay) closeSearch(); });

    input?.addEventListener('input', function() { search(this.value); });
    input?.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowDown') { e.preventDefault(); moveFocus(1); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); moveFocus(-1); }
      else if (e.key === 'Enter') {
        const focused = resultsList.querySelector('.focused');
        if (focused) { focused.click(); closeSearch(); }
      }
      else if (e.key === 'Escape') closeSearch();
    });

    document.addEventListener('keydown', function(e) {
      if ((e.ctrlKey || e.metaKey) && e.key === 'k') { e.preventDefault(); overlay.hasAttribute('hidden') ? openSearch() : closeSearch(); }
      if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) closeSearch();
    });
  })();
</script>
