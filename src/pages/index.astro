---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../config';
import CategoryCard from '../components/CategoryCard.astro';
import LatestNewsSection from '../components/LatestNewsSection.astro';
import { Target, BarChart3, Lightbulb, CheckCircle2, Search, Users, RefreshCw } from 'lucide-astro';
import { getCollection } from 'astro:content';

const siteUrl = SITE_CONFIG.url;
const homepageSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${siteUrl}/#website`,
    url: siteUrl,
    name: SITE_CONFIG.name,
    description: SITE_CONFIG.description,
    publisher: { '@id': `${siteUrl}/#organization` },
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `${siteUrl}/posts?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
    inLanguage: 'en-US',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: SITE_CONFIG.name,
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: `${siteUrl}/images/brand/logo.png` },
    foundingDate: String(SITE_CONFIG.foundedYear),
    description: SITE_CONFIG.tagline,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'SaaS Tools', url: `${siteUrl}/saas` },
      { '@type': 'ListItem', position: 2, name: 'Software', url: `${siteUrl}/software` },
      { '@type': 'ListItem', position: 3, name: 'Comparisons', url: `${siteUrl}/posts` },
      { '@type': 'ListItem', position: 4, name: 'Buying Guides', url: `${siteUrl}/guides` },
    ],
  },
];

const allPosts = await getCollection('posts', ({ data }) => data.draft !== true);
const totalReviews = allPosts.length;

const getPostDate = (post: (typeof allPosts)[number]) => {
  const raw = post.data.date || post.data.pubDate;
  return raw ? new Date(raw) : new Date(0);
};
const sortedPosts = allPosts.sort((a, b) => getPostDate(b).getTime() - getPostDate(a).getTime());
const articles = sortedPosts.map((post) => {
  const date = getPostDate(post);
  return {
    title: post.data.title,
    description: post.data.description,
    category: post.data.category || 'SaaS',
    image: post.data.cover || post.data.image || '/images/posts/default-post.jpg',
    href: `/posts/${post.slug}`,
    date: date.getTime() > 0 ? date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) : '',
    readTime: post.data.readTime || '5 min',
    featured: post.data.featured || false,
  };
});
---

<BaseLayout extraSchema={homepageSchema}>

  <!-- Hero Section -->
  <header class="hero">
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">

        <h1 class="hero-headline">
          Spot the Best.<br/>
          <span class="hero-headline-accent">Go Confident.</span>
        </h1>

        <p class="hero-description">
          Independent reviews on software and SaaS tools — so professionals and business owners choose smarter, every time.
        </p>

        <div class="hero-cta">
          <a href="#latest-news" class="btn btn-primary">Explore Reviews</a>
          <a href="/guides" class="btn btn-outline">Buying Guides</a>
        </div>

        <!-- Social proof bar -->
        <div class="hero-proof">
          <div class="proof-item">
            <span class="proof-number">{totalReviews}</span>
            <span class="proof-label">Reviews Published</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <span class="proof-number">4</span>
            <span class="proof-label">Categories</span>
          </div>
          <div class="proof-divider"></div>
          <div class="proof-item">
            <span class="proof-number">Zero</span>
            <span class="proof-label">Sponsored Reviews</span>
          </div>
        </div>

      </div>
    </div>
  </header>

  <!-- Latest News -->
  <section id="latest-news">
    <LatestNewsSection articles={articles} />
  </section>

  <!-- Categories -->
  <section class="categories" id="categories">
    <div class="container">
      <h2 class="section-title">What We Review</h2>
      <p class="section-subtitle">Independent analysis and buying guides to help professionals and business owners make smarter software decisions</p>
      <div class="categories-grid">
        <CategoryCard title={SITE_CONFIG.categories.saas.name} description={SITE_CONFIG.categories.saas.description} icon={SITE_CONFIG.categories.saas.icon} href="/saas" />
        <CategoryCard title={SITE_CONFIG.categories.software.name} description={SITE_CONFIG.categories.software.description} icon={SITE_CONFIG.categories.software.icon} href="/software" />
        <CategoryCard title={SITE_CONFIG.categories.comparisons.name} description={SITE_CONFIG.categories.comparisons.description} icon={SITE_CONFIG.categories.comparisons.icon} href="/posts" />
        <CategoryCard title={SITE_CONFIG.categories.guides.name} description={SITE_CONFIG.categories.guides.description} icon={SITE_CONFIG.categories.guides.icon} href="/guides" />
      </div>
    </div>
  </section>

  <!-- Why Trust Us -->
  <section class="trust">
    <div class="container">
      <h2 class="section-title">Why Trust InSpotGO?</h2>
      <div class="trust-grid">
        <div class="trust-item">
          <div class="trust-icon"><CheckCircle2 size={56} stroke-width={1.5} /></div>
          <h3>Independent Analysis</h3>
          <p>Honest reviews following editorial standards — no sponsored content, no vendor influence</p>
        </div>
        <div class="trust-item">
          <div class="trust-icon"><Search size={56} stroke-width={1.5} /></div>
          <h3>Comprehensive Research</h3>
          <p>Every review backed by hands-on testing, feature analysis, and real user feedback</p>
        </div>
        <div class="trust-item">
          <div class="trust-icon"><Users size={56} stroke-width={1.5} /></div>
          <h3>Professional Focus</h3>
          <p>Content built for professionals and business owners — not casual consumers</p>
        </div>
        <div class="trust-item">
          <div class="trust-icon"><RefreshCw size={56} stroke-width={1.5} /></div>
          <h3>Evergreen Content</h3>
          <p>Reviews written to stay relevant — benefit-focused, not tied to temporary pricing or promotions</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Editorial Standards -->
  <section class="featured">
    <div class="container">
      <h2 class="section-title">Our Editorial Standards</h2>
      <p class="section-subtitle">Independent SaaS and software journalism with transparent methodology</p>
      <div class="coming-soon-grid">
        <div class="coming-soon-card">
          <div class="card-icon"><Target size={48} stroke-width={1.5} /></div>
          <h3>In-Depth Reviews</h3>
          <p>Detailed analysis of features, real-world use cases, and who each tool is actually built for</p>
        </div>
        <div class="coming-soon-card">
          <div class="card-icon"><BarChart3 size={48} stroke-width={1.5} /></div>
          <h3>Head-to-Head Comparisons</h3>
          <p>Side-by-side breakdowns of competing tools with clear, opinionated recommendations</p>
        </div>
        <div class="coming-soon-card">
          <div class="card-icon"><Lightbulb size={48} stroke-width={1.5} /></div>
          <h3>Buying Guides</h3>
          <p>Decision frameworks that match the right tool to your workflow, team size, and budget</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to Choose the Right Tool?</h2>
      <p>Browse independent reviews and comparisons — no sponsored content, no fluff</p>
      <a href="#latest-news" class="btn btn-cta">Browse Latest Reviews &rarr;</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    background-color: #1e1150;
    background-image: url('/images/banners/hero-home.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    color: white;
    padding: 3.5rem 0 3rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    width: 100%;
    max-width: 100vw;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(30,17,80,0.55) 0%, rgba(46,17,85,0.50) 100%);
    pointer-events: none;
    z-index: 0;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(249,115,22,0.12) 0%, transparent 70%);
    pointer-events: none;
    z-index: 1;
  }
  .hero-content {
    max-width: 780px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }
  .hero-headline {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
    color: white;
  }
  .hero-headline-accent {
    background: var(--gradient-logo-go, linear-gradient(90deg, #f97316, #ec4899));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-description {
    font-size: 1.15rem;
    line-height: 1.7;
    color: rgba(255,255,255,0.82);
    max-width: 600px;
    margin: 0 auto 2.25rem;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .hero-proof {
    display: inline-flex;
    align-items: center;
    gap: 1.5rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.14);
    border-radius: 100px;
    padding: 0.6rem 2rem;
  }
  .proof-item { display: flex; flex-direction: column; align-items: center; }
  .proof-number { font-size: 1.1rem; font-weight: 800; color: white; line-height: 1; }
  .proof-label { font-size: 0.65rem; color: rgba(255,255,255,0.6); letter-spacing: 0.04em; text-transform: uppercase; margin-top: 0.15rem; }
  .proof-divider { width: 1px; height: 28px; background: rgba(255,255,255,0.18); }
  .btn { display: inline-block; padding: 0.9rem 1.875rem; font-size: 1rem; font-weight: 600; text-decoration: none; border-radius: var(--radius-md); transition: all 0.2s ease; border: 2px solid transparent; }
  .btn-primary { background: var(--gradient-action); color: white; box-shadow: 0 4px 16px rgba(249,115,22,0.35); }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(249,115,22,0.45); }
  .btn-outline { background: transparent; color: white; border: 2px solid rgba(255,255,255,0.55); }
  .btn-outline:hover { background: rgba(255,255,255,0.12); border-color: white; }
  .btn-cta { background: white; color: var(--color-primary); font-size: 1.1rem; padding: 1.1rem 2.25rem; border-radius: var(--radius-lg); }
  .btn-cta:hover { background: #f7f7f7; transform: translateY(-2px); box-shadow: 0 6px 24px rgba(0,0,0,0.2); }
  .categories { background: var(--color-bg-alt); padding: 5rem 0; width: 100%; max-width: 100vw; overflow: hidden; }
  .section-title { font-size: 2.25rem; font-weight: 800; color: var(--color-text); margin-bottom: 0.75rem; text-align: center; }
  .section-subtitle { font-size: 1.1rem; color: var(--color-text-light); max-width: 700px; margin: 0 auto 3rem; text-align: center; }
  .categories-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 2rem; margin-top: 3rem; }
  .trust { background: white; padding: 5rem 0; width: 100%; max-width: 100vw; overflow: hidden; }
  .trust-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 3rem; margin-top: 3rem; }
  .trust-item { text-align: center; padding: 2rem 1.5rem; background: var(--color-bg-alt); border-radius: var(--radius-lg); transition: all 0.2s; border: 1px solid var(--color-border); }
  .trust-item:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--color-primary-light); }
  .trust-icon { display: inline-flex; align-items: center; justify-content: center; width: 80px; height: 80px; background: var(--gradient-action); border-radius: var(--radius-full); margin: 0 auto 1.5rem; color: white; }
  .trust-item h3 { font-size: 1.2rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem; }
  .trust-item p { font-size: 0.95rem; color: var(--color-text-light); line-height: 1.6; }
  .featured { background: var(--color-bg-alt); padding: 5rem 0; width: 100%; max-width: 100vw; overflow: hidden; }
  .coming-soon-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2.5rem; margin-top: 3rem; }
  .coming-soon-card { background: white; border: 1px solid var(--color-border); border-radius: var(--radius-lg); padding: 2.5rem 2rem; text-align: center; transition: all 0.2s; box-shadow: var(--shadow-sm); }
  .coming-soon-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-xl); border-color: var(--color-primary); }
  .card-icon { display: inline-flex; align-items: center; justify-content: center; width: 72px; height: 72px; background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-light) 100%); border-radius: var(--radius-lg); margin: 0 auto 1.5rem; color: white; }
  .coming-soon-card h3 { font-size: 1.35rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.875rem; }
  .coming-soon-card p { font-size: 0.975rem; color: var(--color-text-light); line-height: 1.65; }
  .cta-section { background: var(--gradient-hero); padding: 5rem 0; text-align: center; color: white; width: 100%; max-width: 100vw; overflow: hidden; }
  .cta-section h2 { font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem; }
  .cta-section p { font-size: 1.2rem; margin-bottom: 2.5rem; opacity: 0.9; }
  @media (max-width: 768px) {
    .hero { padding: 2.5rem 0 2rem; }
    .hero-proof { flex-wrap: wrap; gap: 1rem; padding: 0.75rem 1.25rem; border-radius: 16px; }
    .proof-divider { display: none; }
    .categories { padding: 3rem 0; }
    .section-title { font-size: 1.875rem; }
    .categories-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .trust { padding: 3rem 0; }
    .trust-grid { grid-template-columns: 1fr; gap: 2rem; }
    .featured { padding: 3rem 0; }
    .coming-soon-grid { grid-template-columns: 1fr; gap: 2rem; }
    .cta-section { padding: 3rem 0; }
    .cta-section h2 { font-size: 2rem; }
  }
</style>
